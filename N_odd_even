import java.util.*;
public class N_odd_even{
  public static void main(String[] args){
    Scanner sc = new Scanner(System.in);
    int odd = 0,even = 0;
    System.out.println("Enter the 5 number:");
    for(int i = 0;i < 5;i++){
      int n = sc.nextInt();
      if(n % 2==0){
        even++;
      }
      else{
        odd++;
      }
      
    }
    System.out.println("Even Num :"+even);
    System.out.println("Odd Num :"+odd);
  }
}